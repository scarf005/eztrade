root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true

[*.fs]
indent_style = space
indent_size = 4
max_line_length = 160
fsharp_max_value_binding_width = 160
fsharp_max_function_binding_width = 160
fsharp_max_if_then_else_short_width = 160
fsharp_max_infix_operator_expression = 160
fsharp_blank_lines_around_nested_multiline_expressions = false
